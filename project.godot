config_version=5

[application]

config/name="ASSteroids"
run/main_scene="uid://b25orbgb57x5e"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://d3ivwjxu7fxrb"

[autoload]

Global="*uid://cuw481iqsq5x6"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[global_group]

asteroids="Cada asteroide nuevo que se haga se meterá acá para mantener orden y que funcionen todos iguales"
bullets="Todo tipo de objetos que se consideren balas irán aquí"
asteroidkillers="Este es un grupo para contener los muros que destruiran los asteroides que no se dirijan al jugador"
player="El fokin jugador, pues quién más"

